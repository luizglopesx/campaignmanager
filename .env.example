# ============================================
# Campaign Manager - Environment Variables
# ============================================

# --- Database (PostgreSQL) ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=campaign_user
DB_PASSWORD=campaign_pass_2026
DB_NAME=campaign_manager
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}

# --- JWT ---
JWT_SECRET=your-super-secret-jwt-key-change-me
JWT_EXPIRES_IN=7d

# --- Server ---
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# --- Chatwoot ---
CHATWOOT_URL=https://your-chatwoot.com
CHATWOOT_API_TOKEN=your-chatwoot-api-token
CHATWOOT_ACCOUNT_ID=1

# --- WuzAPI (fzap) ---
WUZAPI_ENDPOINT=http://your-wuzapi:8080
WUZAPI_TOKEN=your-wuzapi-token
WUZAPI_INSTANCE_ID=default

# --- Supabase Storage (imagens) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-key
SUPABASE_STORAGE_BUCKET=campaign-images

# --- Throttling (WhatsApp) ---
MESSAGE_DELAY_MS=3000
MAX_MESSAGES_PER_MINUTE=20
